---
---

<div class="fl-orbit" aria-hidden="true">
  <span class="fl-el fl-el--tag fl-p1">&lt;/&gt;</span>
  <span class="fl-el fl-el--tag fl-p2">&lt;/&gt;</span>
  <span class="fl-el fl-el--box fl-p3">&gt;_</span>
  <span class="fl-el fl-el--box-sm fl-p4">&gt;_</span>
  <span class="fl-el fl-el--sym fl-p5">f<sub>x</sub></span>
  <span class="fl-el fl-el--sym fl-p6">&#247;</span>
  <span class="fl-el fl-el--diamond fl-p7">&#9670;</span>
  <span class="fl-el fl-el--diamond fl-p8">&#9670;</span>
  <span class="fl-el fl-el--ring fl-p9"></span>
  <span class="fl-el fl-el--ring fl-p10"></span>
  <span class="fl-el fl-el--ring-sm fl-p11"></span>
  <span class="fl-el fl-el--dot fl-p12"></span>
  <span class="fl-el fl-el--dot fl-p13"></span>
  <span class="fl-el fl-el--dot fl-p14"></span>
  <span class="fl-el fl-el--dot fl-p15"></span>
  <span class="fl-el fl-el--dot fl-p16"></span>
  <span class="fl-el fl-el--dot fl-p17"></span>
  <span class="fl-el fl-el--star fl-p18">&#10022;</span>
  <span class="fl-el fl-el--star fl-p19">&#10022;</span>
  <span class="fl-el fl-el--triangle fl-p20">&#9650;</span>
</div>

<style>
  .fl-orbit {
    position: absolute;
    width: 600px;
    height: 440px;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -55%);
    pointer-events: none;
  }

  .fl-el {
    position: absolute;
  }

  .fl-el--tag {
    font-family: var(--font-mono);
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-accent);
    opacity: 0.6;
  }

  .fl-el--box {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--color-txt-3);
    background: var(--color-bg-2);
    border: 1.5px solid var(--color-border);
    padding: 5px 12px;
    border-radius: 7px;
    opacity: 0.65;
  }

  [data-theme="dark"] .fl-el--box {
    background: rgba(255,255,255,0.06);
    border-color: rgba(255,255,255,0.12);
    color: rgba(255,255,255,0.5);
  }

  .fl-el--box-sm {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 700;
    color: var(--color-txt-3);
    background: var(--color-bg-2);
    border: 1.5px solid var(--color-border);
    padding: 3px 9px;
    border-radius: 5px;
    opacity: 0.5;
  }

  [data-theme="dark"] .fl-el--box-sm {
    background: rgba(255,255,255,0.05);
    border-color: rgba(255,255,255,0.1);
    color: rgba(255,255,255,0.4);
  }

  .fl-el--sym {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-txt-3);
    opacity: 0.5;
  }

  .fl-el--diamond {
    font-size: 0.7rem;
    color: var(--color-accent);
    opacity: 0.55;
  }

  .fl-el--ring {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    border: 1.5px solid var(--color-accent);
    opacity: 0.35;
  }

  .fl-el--ring-sm {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    border: 1.5px solid var(--color-txt-3);
    opacity: 0.3;
  }

  .fl-el--dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--color-txt-3);
    opacity: 0.4;
  }

  [data-theme="dark"] .fl-el--dot {
    background: var(--color-accent);
    opacity: 0.35;
  }

  .fl-el--triangle {
    font-size: 0.55rem;
    color: var(--color-txt-3);
    opacity: 0.4;
  }

  .fl-el--star {
    font-size: 0.6rem;
    color: var(--color-accent);
    opacity: 0.45;
  }

  /* left side — top to bottom */
  .fl-p1  { top: 20%; left: 8%; }
  .fl-p5  { top: 34%; left: 4%; }
  .fl-p9  { top: 22%; left: 0%; }
  .fl-p4  { top: 55%; left: 5%; }
  .fl-p12 { top: 10%; left: 20%; }
  .fl-p15 { top: 42%; left: 14%; }
  .fl-p20 { top: 70%; left: 25%; }

  /* right side — top to bottom */
  .fl-p2  { top: 42%; right: 3%; }
  .fl-p3  { top: 14%; right: 5%; }
  .fl-p6  { top: 20%; right: 24%; }
  .fl-p7  { top: 60%; right: 20%; }
  .fl-p10 { top: 38%; right: 10%; }
  .fl-p13 { top: 8%;  right: 14%; }
  .fl-p16 { top: 52%; right: 28%; }

  /* scattered accents */
  .fl-p8  { top: 68%; left: 12%; }
  .fl-p11 { top: 48%; right: 0%; }
  .fl-p14 { top: 74%; right: 12%; }
  .fl-p17 { top: 30%; left: 22%; }
  .fl-p18 { top: 12%; right: 32%; }
  .fl-p19 { top: 64%; left: 2%; }

  @media (max-width: 700px) {
    .fl-orbit {
      display: none;
    }
  }
</style>
